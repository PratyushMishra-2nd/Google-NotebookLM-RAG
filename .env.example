# Provide at least one key. Users can also paste their own key in the UI,
# in which case the provider is auto-detected from the key shape
# (sk-… → OpenAI, AIza… → Gemini).

# Google Gemini API key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant vector DB (optional). When QDRANT_URL is set, embeddings persist in
# Qdrant instead of the ephemeral in-memory store. Leave unset for local/demo.
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Optional model overrides
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_EMBED_MODEL=gemini-embedding-001
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
